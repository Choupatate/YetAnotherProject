# Where story folders live. Back this directory up — it is all your data.
STORYBOOK_STORIES_DIR=./stories

# Shared password for the one login this app has. Required in production;
# if unset, dev mode accepts the password "dev".
STORYBOOK_PASSWORD=changeme

# Flask session-signing key. Required whenever STORYBOOK_PASSWORD is set (the
# app refuses to start otherwise). In dev mode (no password set) a random one
# is generated at startup, which invalidates sessions on restart.
STORYBOOK_SECRET_KEY=change-this-to-a-long-random-string

# Set to 1 when serving over HTTPS to mark the session cookie Secure (it is
# never sent over plain HTTP). Leave unset/0 for local/LAN HTTP use.
STORYBOOK_COOKIE_SECURE=0

# Optional: let several family members write in the same shared timeline,
# each with their own color. Comma-separated Name:#hexcolor pairs. Leave
# unset to disable the feature entirely (no author picker, no bylines, no
# legend). Renaming an author here does not rewrite already-saved stories.
# STORYBOOK_AUTHORS="Papa:#d9a441,Maman:#7ba7d9"
